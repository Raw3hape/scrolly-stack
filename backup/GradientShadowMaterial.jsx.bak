/**
 * GradientShadowMaterial Component
 * 
 * Hybrid material: gradient colors + real shadows
 * Uses onBeforeCompile to inject gradient into standard material.
 */

import { useMemo, useRef } from 'react';
import { useFrame } from '@react-three/fiber';
import * as THREE from 'three';

export default function GradientShadowMaterial({
  colorA = '#f9a8d4',
  colorB = '#fce7f3',
  isActive = false,
}) {
  const shaderRef = useRef(null);
  
  // Create the material with gradient injection
  const material = useMemo(() => {
    const colA = new THREE.Color(colorA);
    const colB = new THREE.Color(colorB);
    
    const mat = new THREE.MeshStandardMaterial({
      color: colA,
      roughness: isActive ? 0.25 : 0.35,
      metalness: 0.02,
      envMapIntensity: 0.4,
    });
    
    mat.onBeforeCompile = (shader) => {
      // Store reference for animation
      shaderRef.current = shader;
      
      // Add custom uniforms
      shader.uniforms.uColorA = { value: colA };
      shader.uniforms.uColorB = { value: colB };
      shader.uniforms.uTime = { value: 0 };
      
      // Inject varyings into vertex shader
      shader.vertexShader = shader.vertexShader.replace(
        'void main() {',
        `
        varying vec3 vPos;
        varying vec3 vNorm;
        void main() {
          vPos = position;
          vNorm = normal;
        `
      );
      
      // Inject uniforms and gradient logic into fragment shader
      shader.fragmentShader = shader.fragmentShader.replace(
        'void main() {',
        `
        uniform vec3 uColorA;
        uniform vec3 uColorB;
        uniform float uTime;
        varying vec3 vPos;
        varying vec3 vNorm;
        void main() {
        `
      );
      
      // Replace diffuse color with enhanced gradient + inner shadows
      // This happens BEFORE lighting calculations, so shadows still work!
      shader.fragmentShader = shader.fragmentShader.replace(
        'vec4 diffuseColor = vec4( diffuse, opacity );',
        `
        // ═══════════════════════════════════════════════════════════════════
        // ENHANCED DIAGONAL GRADIENT (more visible)
        // ═══════════════════════════════════════════════════════════════════
        
        // Stronger gradient factor for more visible transition
        float gradientMix = (vPos.x + vPos.z + 3.0) * 0.2;
        gradientMix = clamp(gradientMix, 0.0, 1.0);
        
        // Add secondary gradient from back to front for more depth
        float depthGradient = (vPos.z + 3.5) * 0.15;
        depthGradient = clamp(depthGradient, 0.0, 0.4);
        
        // Combine gradients
        float totalGradient = clamp(gradientMix + depthGradient, 0.0, 1.0);
        
        // Smooth the gradient for softer blend
        totalGradient = smoothstep(0.0, 1.0, totalGradient);
        
        // Subtle animated shimmer
        float shimmer = sin(uTime * 0.4 + vPos.x * 1.2 + vPos.z * 0.8) * 0.04;
        totalGradient = clamp(totalGradient + shimmer, 0.0, 1.0);
        
        // Mix colors A to B
        vec3 gradientColor = mix(uColorA, uColorB, totalGradient);
        
        // ═══════════════════════════════════════════════════════════════════
        // INNER SHADOWS (pseudo ambient occlusion)
        // ═══════════════════════════════════════════════════════════════════
        
        // Slightly darker on side faces
        float sideShade = 1.0 - abs(vNorm.x) * 0.15 - abs(vNorm.z) * 0.1;
        
        // Darker on bottom-facing normals
        float bottomShade = mix(0.8, 1.0, (vNorm.y + 1.0) * 0.5);
        
        // Combined inner shadow
        float innerShadow = sideShade * bottomShade;
        
        // Apply inner shadow to gradient
        gradientColor *= innerShadow;
        
        vec4 diffuseColor = vec4( gradientColor, opacity );
        `
      );
    };
    
    return mat;
  }, [colorA, colorB, isActive]);
  
  // Update time uniform every frame using ref
  useFrame((state) => {
    if (shaderRef.current) {
      shaderRef.current.uniforms.uTime.value = state.clock.elapsedTime;
    }
  });
  
  return <primitive object={material} attach="material" />;
}
