{
  "name": "scrolly-stack",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src e2e playwright.config.ts --max-warnings=0",
    "typecheck": "npm run typecheck:app && npm run typecheck:e2e",
    "typecheck:app": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=desktop-1440 e2e/pages.spec.ts e2e/navigation.spec.ts",
    "check:palette": "node scripts/check-palette-sync.mjs"
  },
  "dependencies": {
    "@react-spring/three": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.182.0",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.4",
    "three": "^0.182.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/parser": "^8.57.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",

    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",

    "globals": "^16.5.0",
    "typescript": "^5.9.3"
  }
}
